#!/bin/zsh

#####################
# Prompt Decoration #
#####################

# Load `fg` and etc...
# @See https://wiki.archlinux.org/title/Zsh#Colors for more details
autoload -U colors && colors

function colorize_text_by_status() {
    local _t=$1 _s=$2
    local statuscolor
    if [[ $_s =~ "fatal" ]]; then
        # Not in git repository
        statuscolor=${fg[white]}
    elif [[ -z $_s ]]; then
        # Clean
        statuscolor=${fg[green]}
    elif [[ $_s =~ "[\n]?\?\? " ]]; then
        # Untracked
        statuscolor=${fg[yellow]}
    elif [[ $_s =~ "[\n]? M " ]]; then
        # Modified
        statuscolor=${fg[red]}
    else
        # Added to commit (Staged)
        statuscolor=${fg[cyan]}
    fi
    echo ${statuscolor}${_t}${reset_color}
}

function generate_prompt() {
    local _loc=`basename ${PWD}`
    if [[ "$PWD" =~ '/\.git(/.*)?$' ]]; then # Inside .git directory
        echo ${_loc}' %% '
        return
    fi
    local _st=`git status -s 2>&1`
    if [[ $_st =~ "fatal" ]]; then # Not in git-managed directory
        echo ${_loc}' %% '
        return
    fi
    local _br=`git rev-parse --abbrev-ref HEAD 2> /dev/null`
    echo ${_loc} `colorize_text_by_status ${_br} ${_st}`' %% '
}

PROMPT=$'`generate_prompt`'
setopt prompt_subst # To evaluate PROMPT everytime when displayed

function pre() {
    PROMPT='%% '
}
function rich() {
    PROMPT=$'`generate_prompt`'
}

############################
# Tab Title & Color (OSC)  #
############################

# タブタイトルをディレクトリ名+ブランチにする（プロンプト表示ごと）
function precmd() {
    local _br=$(git symbolic-ref --short HEAD 2>/dev/null)
    if [[ -n $_br ]]; then
        print -Pn "\033]2;%1~ ($_br)\007"
    else
        print -Pn "\033]2;%1~\007"
    fi
}

# ターミナル背景色をディレクトリごとに固定色にする（cd 時のみ）
# プリセットの暗め背景色から、ディレクトリのハッシュで1つ選ぶ
_DIR_BG_COLORS=(
    "0d1117"  # 黒青（GitHub Dark） hue≈220°
    "1a0d2e"  # 深紫               hue≈270°
    "0d2a0d"  # 深緑               hue≈120°
    "2a0d0d"  # 深赤               hue≈  0°
    "0d1f2a"  # 深青緑             hue≈200°
    "2a1500"  # 深琥珀             hue≈ 30°
    "2a002a"  # 深マゼンタ         hue≈300°
    "1f1f00"  # 深オリーブ         hue≈ 60°
)
function mood() {
    (( ${#_DIR_BG_COLORS[@]} == 0 )) && return
    local idx=$(( RANDOM % ${#_DIR_BG_COLORS[@]} + 1 ))
    printf "\033]11;#${_DIR_BG_COLORS[$idx]}\007"
}

function chpwd() {
    (( ${#_DIR_BG_COLORS[@]} == 0 )) && return
    local hash=$(echo -n "$PWD$(date +%Y%m%d)" | md5 | cut -c1-2)
    local idx=$(( 16#$hash % ${#_DIR_BG_COLORS[@]} + 1 ))
    printf "\033]11;#${_DIR_BG_COLORS[$idx]}\007"
}
chpwd
